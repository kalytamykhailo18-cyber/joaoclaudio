# Banco de dados PostgreSQL (CMS)
DATABASE_URI=postgres://USUARIO:SENHA@127.0.0.1:5432/joaoclaudio
# Chave secreta do Payload (gerar aleatória, manter em segredo)
PAYLOAD_SECRET=troque-por-uma-chave-aleatoria-longa
# URL pública do site
NEXT_PUBLIC_SITE_URL=https://joaoclaudiomiranda.com
# Google Tag Manager (contêiner instalado no site)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Google Analytics 4 (Measurement ID) — mede pageviews + eventos de conversão
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Ads (opcional) — preencha quando a conta de Ads existir. Sem estas
# variáveis, nada de Ads é carregado. Ao preencher, o site passa a: (1) registrar
# a origem da campanha (gclid/UTM) e anexá-la às conversões; (2) ativar a tag de
# remarketing; (3) disparar conversão de Ads no clique de WhatsApp/telefone.
NEXT_PUBLIC_GADS_ID=                    # ex.: AW-123456789
NEXT_PUBLIC_GADS_LABEL_WHATSAPP=        # rótulo da conversão "clique no WhatsApp"
NEXT_PUBLIC_GADS_LABEL_PHONE=           # rótulo da conversão "clique no telefone"
# Avaliacoes ao vivo do Google (opcional) — Places API key + place_id do perfil
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
